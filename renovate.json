{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Auto-merge everything — major/minor/patch/pin/digest — once required CI (PSScriptAnalyzer lint + Pester tests) is green. CI is the gate, not semver.",
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["github-actions"],
      "pinDigests": true
    }
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 3
}
